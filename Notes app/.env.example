# Second Brain — Notes App
# Copy to .env and fill in values. NEVER commit .env to git.

# ClickUp
CLICKUP_API_KEY=
CLICKUP_DEFAULT_LIST_ID=

# Microsoft Graph API (for Calendar, Teams, OneDrive)
MS_GRAPH_CLIENT_ID=
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_SECRET=

# Azure Speech SDK (voice dictation)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Copilot / Azure OpenAI
COPILOT_API_ENDPOINT=
COPILOT_API_KEY=

# App config
STORAGE_ROOT=~/SecondBrain
NODE_ENV=development
